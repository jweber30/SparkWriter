#!/bin/sh
set -e

case "$1" in
    configure)
        # Update icon cache for hicolor theme
        if [ -x /usr/bin/gtk-update-icon-cache ]; then
            gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor || true
        fi
        
        # Update desktop database
        if [ -x /usr/bin/update-desktop-database ]; then
            update-desktop-database -q /usr/share/applications || true
        fi
        
        # Remove old cached icon and copy new icon to user's local directory for Chrome OS/Crostini shelf
        # This helps Chrome OS find the icon after reboot
        for user_home in /home/*; do
            if [ -d "$user_home" ] && [ "$user_home" != "/home/chronos" ]; then
                user=$(basename "$user_home")
                local_icon_dir="$user_home/.local/share/icons/hicolor/48x48/apps"
                
                # Remove old cached icon first to force refresh
                if [ -f "$local_icon_dir/spark-writer.png" ]; then
                    rm -f "$local_icon_dir/spark-writer.png" 2>/dev/null || true
                fi
                
                if [ ! -d "$local_icon_dir" ]; then
                    sudo -u "$user" mkdir -p "$local_icon_dir" 2>/dev/null || true
                fi
                
                if [ -d "$local_icon_dir" ] && [ -f /usr/share/icons/hicolor/48x48/apps/spark-writer.png ]; then
                    cp /usr/share/icons/hicolor/48x48/apps/spark-writer.png "$local_icon_dir/" 2>/dev/null || true
                    chown "$user:$user" "$local_icon_dir/spark-writer.png" 2>/dev/null || true
                fi
            fi
        done
        ;;
    
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    
    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
