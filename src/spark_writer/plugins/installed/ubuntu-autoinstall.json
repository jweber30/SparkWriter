{
  "version": "1.6",
  "metadata": {
    "id": "ubuntu-autoinstall",
    "name": "Ubuntu Autoinstall",
    "version": "1.0.0",
    "author": "MetalStrapper",
    "description": "Ubuntu Server autoinstall with cloud-init. Generates ephemeral password shown only once after write completes."
  },
  "requires": {
    "commands": [
      {
        "name": "mkpasswd",
        "package": "whois",
        "description": "Generate password hashes for autoinstall workflows",
        "install_hint": "Install the whois package to provide mkpasswd",
        "allow_plugin_specific": true
      }
    ]
  },
  "source": {
    "id": "ubuntu-24.04-server-autoinstall",
    "name": "Ubuntu 24.04 LTS Server Autoinstall",
    "family": "ubuntu",
    "version": "24.04",
    "url": "https://releases.ubuntu.com/24.04/ubuntu-24.04.3-live-server-amd64.iso",
    "installer_scheme": "ubuntu-nocloud",
    "capabilities": ["cloud-init-nocloud"]
  },
  "outputs": {
    "usb": true,
    "iso": true
  },
  "ui_visibility": {
    "when": {
      "source_family": ["ubuntu"],
      "installer_scheme": ["ubuntu-nocloud"]
    }
  },
  "config_fields": [
    {
      "id": "hostname",
      "label": "Hostname",
      "type": "text",
      "placeholder": "ubuntu-server",
      "description": "System hostname",
      "required": true
    },
    {
      "id": "username",
      "label": "Admin Username",
      "type": "text",
      "default": "ubuntu",
      "description": "Initial admin user (will have sudo access)",
      "required": true
    },
    {
      "id": "ssh-keys",
      "label": "SSH Public Keys",
      "type": "multiline",
      "description": "One public key per line (ssh-rsa, ssh-ed25519, etc.)",
      "required": true,
      "big": true
    },
    {
      "id": "timezone",
      "label": "Timezone",
      "type": "text",
      "default": "America/Denver",
      "description": "System timezone (e.g., America/New_York)"
    },
    {
      "id": "packages",
      "label": "Additional Packages (optional)",
      "type": "text",
      "placeholder": "vim git htop",
      "description": "Space-separated package names to install"
    }
  ],
  "templates": {
    "user_data": "#cloud-config\nautoinstall:\n  version: 1\n  identity:\n    hostname: {{hostname}}\n    username: {{username}}\n    password: {{_generated_password_hash}}\n  user-data:\n    hostname: {{hostname}}\n    fqdn: {{hostname}}.local\n    timezone: {{timezone}}\n    users:\n      - name: {{username}}\n        groups: [sudo, docker]\n        shell: /bin/bash\n        sudo: 'ALL=(ALL) NOPASSWD:ALL'\n        passwd: {{_generated_password_hash}}\n        lock_passwd: false\n        ssh_authorized_keys:\n{{_ssh_keys_yaml}}\n    package_update: true\n    package_upgrade: true\n    packages:\n{{_packages_yaml}}\n    final_message: \"Ubuntu autoinstall complete. Hostname: {{hostname}}\"\n",
    "meta_data": "instance-id: ubuntu-autoinstall-{{hostname}}\nlocal-hostname: {{hostname}}\n"
  },
  "actions": {
    "on_iso_ready": [
      {
        "id": "generate_password",
        "type": "generate_ephemeral_password",
        "length": 16,
        "output_var": "_generated_password_plaintext",
        "emit_event": {
          "message": "Generating secure ephemeral password",
          "progress": 10
        }
      },
      {
        "id": "hash_password",
        "type": "run_command",
        "command": [
          "mkpasswd",
          "--method=yescrypt",
          "{{_generated_password_plaintext}}"
        ],
        "output_var": "_generated_password_hash",
        "emit_event": {
          "message": "Hashing password",
          "progress": 20
        }
      },
      {
        "id": "format_ssh_keys",
        "type": "format_yaml_list",
        "input": "{{ssh-keys}}",
        "indent": 10,
        "output_var": "_ssh_keys_yaml",
        "emit_event": {
          "message": "Formatting SSH keys",
          "progress": 30
        }
      },
      {
        "id": "format_packages",
        "type": "format_yaml_list",
        "input": "{{packages}}",
        "default": "curl wget vim git htop",
        "indent": 6,
        "output_var": "_packages_yaml",
        "emit_event": {
          "message": "Preparing package list",
          "progress": 40
        }
      },
      {
        "id": "render_user_data",
        "type": "render_template",
        "template": "user_data",
        "output_var": "user_data_content",
        "emit_event": {
          "message": "Rendering cloud-init user-data",
          "progress": 50
        }
      },
      {
        "id": "create_user_data_artifact",
        "type": "create_artifact",
        "artifact_id": "user_data",
        "content_var": "user_data_content",
        "kind": "cloud_init",
        "logical_name": "user-data",
        "media_type": "text/cloud-config",
        "emit_event": {
          "message": "Registering cloud-init user-data artifact",
          "progress": 55
        }
      },
      {
        "id": "render_meta_data",
        "type": "render_template",
        "template": "meta_data",
        "output_var": "meta_data_content",
        "emit_event": {
          "message": "Rendering cloud-init meta-data",
          "progress": 60
        }
      },
      {
        "id": "create_meta_data_artifact",
        "type": "create_artifact",
        "artifact_id": "meta_data",
        "content_var": "meta_data_content",
        "kind": "cloud_init",
        "logical_name": "meta-data",
        "media_type": "text/plain",
        "emit_event": {
          "message": "Registering cloud-init meta-data artifact",
          "progress": 65
        }
      },
      {
        "id": "inject_cloud_init",
        "type": "prepare_installer_iso",
        "installer_scheme": "ubuntu-nocloud",
        "iso_path": "{{iso_path}}",
        "output_path": "{{iso_path}}",
        "artifact_map": {
          "user-data": "user_data",
          "meta-data": "meta_data"
        },
        "options": {
          "volume_label": "Ubuntu_Auto"
        },
        "emit_event": {
          "message": "Injecting cloud-init configuration into ISO",
          "progress": 80
        }
      },
      {
        "id": "store_password",
        "type": "store_ephemeral_secret",
        "key": "admin_password",
        "value": "{{_generated_password_plaintext}}",
        "emit_event": {
          "message": "Storing password in memory (will be shown after write)",
          "progress": 100
        }
      }
    ],
    "on_write_complete": [
      {
        "id": "show_password_button",
        "type": "show_ephemeral_secret_button",
        "key": "admin_password",
        "button_label": "Reveal Admin Password",
        "message_template": "Admin password for {{username}}@{{hostname}}: {{admin_password}}",
        "auto_destroy": true,
        "emit_event": {
          "message": "USB write complete. Click button to reveal password.",
          "progress": 100
        }
      }
    ]
  }
}
