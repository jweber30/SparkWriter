{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metalstrapper.net/schemas/sparkplug-manifest-v1.json",
  "title": "SparkPlug Manifest",
  "description": "SparkPlug manifests target SparkWriter running in a freshly provisioned Crostini environment. External command dependencies are expected to be satisfiable via apt-compatible Debian packages unless otherwise noted.",
  "type": "object",
  "required": ["version", "metadata", "requires"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Manifest schema version",
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique plugin identifier (lowercase, hyphens)",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "description": "Human-readable plugin name"
        },
        "version": {
          "type": "string",
          "description": "Plugin version (semver recommended)"
        },
        "author": {
          "type": "string",
          "description": "Plugin author name or organization"
        },
        "description": {
          "type": "string",
          "description": "Brief description of plugin functionality"
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "Plugin homepage or repository URL"
        },
        "github_username": {
          "type": "string",
          "description": "GitHub username for GitHub-hosted manifest authorization",
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37})$"
        },
        "signature": {
          "type": "object",
          "description": "Manifest authorization signature metadata",
          "required": ["openssh", "algorithm"],
          "properties": {
            "openssh": {
              "type": "string",
              "description": "ASCII-armored OpenSSH signature generated over canonical manifest payload"
            },
            "algorithm": {
              "type": "string",
              "enum": ["openssh-ssh-ed25519"],
              "description": "Signature algorithm"
            },
            "signed_payload_version": {
              "type": "integer",
              "minimum": 1,
              "description": "Canonical payload format version"
            }
          }
        }
      }
    },
    "requires": {
      "type": "object",
      "description": "External dependencies and runtime requirements",
      "properties": {
        "commands": {
          "type": "array",
          "description": "External commands this plugin invokes",
          "items": {
            "type": "object",
            "required": ["name", "description", "install_hint", "allow_plugin_specific"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Command name (e.g., 'proxmox-auto-install-assistant')"
              },
              "description": {
                "type": "string",
                "description": "Why this command is needed"
              },
              "package": {
                "type": "string",
                "description": "Debian/Ubuntu package that provides this command (e.g., 'whois', 'xorriso')"
              },
              "install_hint": {
                "type": "string",
                "description": "Installation suggestion (e.g., 'apt install xorriso')"
              },
              "allow_plugin_specific": {
                "type": "boolean",
                "default": false,
                "description": "If true, allow this command (requires user confirmation)"
              }
            }
          }
        },
        "python_version": {
          "type": "string",
          "description": "Minimum Python version (e.g., '3.8')"
        }
      }
    },
    "secure_manifest": false,
    "preset_feeds": {
      "type": "array",
      "description": "Remote feeds that provide presets (JSON Feed 1.1 format)",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "HTTPS URL of the preset feed (JSON Feed 1.1)"
          },
          "verify_signature": {
            "type": "boolean",
            "default": false,
            "description": "Verify Ed25519 signature if present (metalstrapper_signature)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of this feed source"
          }
        }
      }
    },
    "presets": {
      "type": "array",
      "description": "Static OS presets this plugin provides",
      "items": {
        "type": "object",
        "required": ["id", "name", "url"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Preset identifier",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string",
            "description": "Display name for preset"
          },
          "url": {
            "type": "string",
            "description": "ISO download URL (http/https/magnet)"
          },
          "sha256": {
            "type": "string",
            "description": "Expected SHA256 checksum of the ISO",
            "pattern": "^[a-f0-9]{64}$"
          },
          "distro": {
            "type": "string",
            "description": "Distribution family (arch, debian, etc.)"
          },
          "metadata": {
            "type": "object",
            "description": "Additional preset metadata",
            "additionalProperties": true
          }
        }
      }
    },
    "config_fields": {
      "type": "array",
      "description": "User-configurable fields shown in UI",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Field identifier (used in templates as {{field_id}})"
          },
          "label": {
            "type": "string",
            "description": "Display label"
          },
          "type": {
            "type": "string",
            "enum": ["text", "password", "select", "multiline", "info"],
            "description": "Input field type"
          },
          "default": {
            "description": "Default value"
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "Whether field is required"
          },
          "description": {
            "type": "string",
            "description": "Help text shown below field"
          },
          "placeholder": {
            "type": "string",
            "description": "Placeholder text for empty fields"
          },
          "big": {
            "type": "boolean",
            "default": false,
            "description": "Use full-width layout (for multiline)"
          },
          "standard_field": {
            "type": "string",
            "description": "Optional semantic field identifier for cross-plugin orchestration/profile reuse",
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
          },
          "storage": {
            "$ref": "#/definitions/storage_hint"
          },
          "options": {
            "type": "array",
            "description": "Options for select type",
            "items": {
              "type": "object",
              "required": ["value", "label"],
              "properties": {
                "value": {
                  "description": "Option value"
                },
                "label": {
                  "type": "string",
                  "description": "Display label"
                }
              }
            }
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "description": "Named sidecar assets that templates or future manifest sections can reference",
      "additionalProperties": {
        "$ref": "#/definitions/asset"
      }
    },
    "templates": {
      "type": "object",
      "description": "Named templates for generating scripts/configs. Values may be inline strings, arrays of lines, or references to local sidecar files/assets.",
      "additionalProperties": {
        "$ref": "#/definitions/template_value"
      }
    },
    "ui_visibility": {
      "type": "object",
      "description": "Conditions for showing plugin UI",
      "properties": {
        "when": {
          "type": "object",
          "description": "Show plugin when condition matches",
          "properties": {
            "preset_distro": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Show only for these distro values"
            },
            "preset_id": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Show only for these preset IDs"
            }
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "description": "Lifecycle hook implementations",
      "properties": {
        "on_iso_ready": {
          "type": "array",
          "description": "Actions to run when ISO is ready for processing",
          "items": {"$ref": "#/definitions/action"}
        },
        "on_write_complete": {
          "type": "array",
          "description": "Actions to run after USB write completes",
          "items": {"$ref": "#/definitions/action"}
        }
      }
    },
    "signature": false
  },
  "definitions": {
    "action": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Action identifier (for logging)"
        },
        "type": {
          "type": "string",
          "enum": [
            "render_template",
            "run_command",
            "compute_file_hash",
            "create_partition",
            "write_partition_files",
            "generate_receipt",
            "format_yaml_list",
            "generate_ephemeral_password",
            "store_ephemeral_secret",
            "show_ephemeral_secret_button",
            "create_artifact",
            "prepare_proxmox_auto_install_iso",
            "prepare_ubuntu_nocloud_iso"
          ],
          "description": "Action type"
        },
        "when": {
          "$ref": "#/definitions/condition",
          "description": "Optional condition to execute this action"
        },
        "template": {
          "type": "string",
          "description": "Template name (for render_template)"
        },
        "output_var": {
          "type": "string",
          "description": "Store result in this variable for later actions"
        },
        "command": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Command and args (for run_command)"
        },
        "sudo": {
          "type": "boolean",
          "default": false,
          "description": "Run command with sudo using -n (non-interactive) flag. Requires passwordless sudo configuration (NOPASSWD in /etc/sudoers). Used for autoinstall workflows that cannot prompt for passwords."
        },
        "artifact_id": {
          "type": "string",
          "description": "Unique runtime artifact identifier for create_artifact"
        },
        "content": {
          "type": "string",
          "description": "Inline text content for create_artifact"
        },
        "content_var": {
          "type": "string",
          "description": "Existing action output variable to store as artifact content"
        },
        "kind": {
          "type": "string",
          "description": "Logical artifact kind such as config, script, or cloud_init"
        },
        "logical_name": {
          "type": "string",
          "description": "Logical filename used when the host materializes an artifact"
        },
        "media_type": {
          "type": "string",
          "description": "Optional media type hint for an artifact"
        },
        "executable": {
          "type": "boolean",
          "default": false,
          "description": "Whether a materialized artifact should be executable"
        },
        "iso_path": {
          "type": "string",
          "description": "Source ISO path for host-owned ISO preparation actions"
        },
        "output_path": {
          "type": "string",
          "description": "Destination ISO path for host-owned ISO preparation actions"
        },
        "answer_artifact": {
          "type": "string",
          "description": "Artifact id for the Proxmox answer file"
        },
        "firstboot_artifact": {
          "type": "string",
          "description": "Optional artifact id for the Proxmox first-boot script"
        },
        "user_data_artifact": {
          "type": "string",
          "description": "Artifact id for Ubuntu NoCloud user-data"
        },
        "meta_data_artifact": {
          "type": "string",
          "description": "Artifact id for Ubuntu NoCloud meta-data"
        },
        "volume_label": {
          "type": "string",
          "description": "Optional output ISO volume label"
        },
        "emit_event": {
          "type": "object",
          "description": "Emit progress event",
          "properties": {
            "message": {"type": "string"},
            "progress": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        }
      }
    },
    "condition": {
      "type": "object",
      "required": ["field", "operator"],
      "properties": {
        "field": {
          "type": "string",
          "description": "Config field ID to evaluate"
        },
        "operator": {
          "type": "string",
          "enum": ["not_empty", "empty", "equals", "not_equals", "in", "not_in"],
          "description": "Comparison operator"
        },
        "value": {
          "description": "Value to compare against (for equals/in operators)"
        }
      }
    },
    "asset": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path to a sidecar file stored beside the manifest"
        },
        "sha256": {
          "type": "string",
          "description": "Optional SHA256 digest for future sidecar integrity verification",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional expected size in bytes"
        },
        "media_type": {
          "type": "string",
          "description": "Optional MIME/media type hint"
        },
        "permissions": {
          "type": "string",
          "pattern": "^[0-7]{3,4}$",
          "description": "Optional file mode hint for downstream tooling"
        }
      },
      "additionalProperties": false
    },
    "template_value": {
      "description": "Template value: inline content, line array, direct file reference, or named asset reference",
      "oneOf": [
        {
          "type": "string",
          "description": "Template string with {{variable}} syntax"
        },
        {
          "type": "array",
          "description": "Template split into lines for readability",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "required": ["file"],
          "properties": {
            "file": {
              "type": "string",
              "description": "Relative sidecar file path beside the manifest"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["asset"],
          "properties": {
            "asset": {
              "type": "string",
              "description": "Asset name from the manifest assets registry"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "storage_hint": {
      "type": "object",
      "description": "Optional persistence hints for hosts/orchestrators",
      "properties": {
        "persist": {
          "type": "boolean",
          "default": false,
          "description": "Whether the host may persist this value for reuse"
        },
        "scope": {
          "type": "string",
          "enum": ["user", "workspace", "plugin", "session", "ephemeral"],
          "description": "Suggested persistence scope"
        },
        "secret": {
          "type": "boolean",
          "default": false,
          "description": "Whether the value should be treated as sensitive"
        }
      },
      "additionalProperties": false
    }
  }
}
